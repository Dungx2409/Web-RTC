# 1. Base image
FROM node:18-alpine

# 2. Tạo thư mục app trong container
WORKDIR /app

# 3. Copy package.json trước để tận dụng cache
COPY package*.json ./

# 4. Cài dependencies (chỉ production)
RUN npm install --only=production

# 5. Copy toàn bộ source code
COPY . .

# 6. Expose port
EXPOSE 3001

# 7. Chạy app
CMD ["node", "server.js"]